<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!--
      packages.config 專案預設會將套件還原到 solution 根目錄下的 packages/，
      但若使用者機器的全域 NuGet.Config 設了 repositoryPath，可能會導致還原位置不同，
      進而讓 mySQLPunk.csproj 內的 ..\\packages\\... HintPath 與 Import 找不到檔案。
      這裡強制把 repositoryPath 鎖定在本 repo 的 packages/，確保 nuget restore 行為一致。
    -->
    <add key="repositoryPath" value="packages" />
  </config>
</configuration>

